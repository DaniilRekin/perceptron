{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "g++.exe build active file",
      "command": "D:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-std=c++20",
        "-g",
        "-o", "${fileDirname}/build/${fileBasenameNoExtension}.exe",
        "src/main.cpp",
        "src/Perceptron.cpp"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}